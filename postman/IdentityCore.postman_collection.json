            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{platform_admin_email}}\",\n  \"password\": \"{{platform_admin_password}}\"\n}"
            },
            "url": "{{baseUrl}}{{restBase}}/auth/login"
          }
        },
        {
          "name": "Organization Onboarding Status",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{dashboard_access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query OrganizationOnboarding { organizationOnboarding { organizationId organizationType organizationTier onboardingStatus currentStep supportEmail phoneNumber website } }\"\n}"
            },
            "url": "{{baseUrl}}{{graphqlPath}}"
          }
        },
        {
          "name": "Submit Organization Verification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{dashboard_access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation SubmitOrganizationVerification($input: OrganizationVerificationInput!) { submitOrganizationOnboardingVerification(input: $input) { nextAction onboarding { organizationVerificationSubmittedAt onboardingStatus currentStep } } }\",\n  \"variables\": {\n    \"input\": {\n      \"businessRegistrationNumber\": \"BRN-2026-001\",\n      \"registeredAddress\": \"10 Liberation Road, Accra\",\n      \"officialWebsite\": \"https://sunrise.example\",\n      \"taxIdentificationNumber\": \"TIN-8899\",\n      \"supportingDocumentKeys\": [\"organizations/documents/certificate.pdf\"]\n    }\n  }\n}"
            },
            "url": "{{baseUrl}}{{graphqlPath}}"
          }
        },
        {
          "name": "Submit Administrator Identity Verification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{dashboard_access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation SubmitAdministratorIdentity($verificationId: String!) { submitAdministratorIdentityOnboardingVerification(verificationId: $verificationId) { nextAction onboarding { administratorIdentityVerificationStatus administratorIdentityVerificationId onboardingStatus currentStep } } }\",\n  \"variables\": {\n    \"verificationId\": \"ver_admin_identity_001\"\n  }\n}"
            },
            "url": "{{baseUrl}}{{graphqlPath}}"
          }
        },
        {
          "name": "Review Organization Onboarding",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{platform_admin_access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation ReviewOrganizationOnboarding($organizationId: String!, $decision: String!, $note: String!) { reviewOrganizationOnboarding(organizationId: $organizationId decision: $decision note: $note) { nextAction onboarding { organizationStatus tenantStatus organizationTier onboardingStatus } } }\",\n  \"variables\": {\n    \"organizationId\": \"{{onboarding_organization_id}}\",\n    \"decision\": \"approved\",\n    \"note\": \"Approved from Postman manual testing.\"\n  }\n}"
            },
            "url": "{{baseUrl}}{{graphqlPath}}"
          }
        }
      ]
    }
  ]
