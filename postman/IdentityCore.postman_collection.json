    {
      "name": "GraphQL - Dashboard",
      "item": [
        {
          "name": "Verifications Query",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{dashboard_access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query VerificationList { verifications(status: \\\"manual_review_required\\\") { id status riskAssessment { riskLevel riskScore } verificationSubject { fullName } } }\"\n}"
            },
            "url": "{{baseUrl}}{{graphqlPath}}"
          }
        },
        {
          "name": "Manual Decision Mutation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{dashboard_access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation ManualDecision($verificationId: String!, $decision: String!, $reasonCode: String!) { recordManualDecision(verificationId: $verificationId decision: $decision reasonCode: $reasonCode) { verificationId decision decisionType } }\",\n  \"variables\": {\n    \"verificationId\": \"{{verification_id}}\",\n    \"decision\": \"verified\",\n    \"reasonCode\": \"evidence_confirmed\"\n  }\n}"
            },
            "url": "{{baseUrl}}{{graphqlPath}}"
          }
        }
      ]
    },
    {
      "name": "GraphQL - Onboarding",
      "item": [
        {
          "name": "Register Organization Onboarding",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const payload = pm.response.json();",
                  "const result = payload.data.registerOrganizationOnboarding;",
                  "pm.environment.set('onboarding_organization_id', result.onboarding.organizationId);",
                  "pm.environment.set('onboarding_admin_user_id', result.onboarding.administratorUserId);",
                  "if (result.debugEmailVerificationUrl) {",
                  "  pm.environment.set('email_verification_debug_url', result.debugEmailVerificationUrl);",
                  "  const token = result.debugEmailVerificationUrl.split('token=')[1] || '';",
                  "  pm.environment.set('email_verification_token', decodeURIComponent(token));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation RegisterOnboarding($input: RegisterOrganizationOnboardingInput!) { registerOrganizationOnboarding(input: $input) { nextAction debugEmailVerificationUrl onboarding { organizationId administratorUserId organizationName organizationTier onboardingStatus currentStep } } }\",\n  \"variables\": {\n    \"input\": {\n      \"fullName\": \"Ama Mensah\",\n      \"businessEmail\": \"ama@sunrise.example\",\n      \"password\": \"StrongPassword123!\",\n      \"country\": \"GH\",\n      \"organizationName\": \"Sunrise Health\",\n      \"organizationType\": \"healthcare_provider\",\n      \"organizationCountry\": \"GH\",\n      \"website\": \"https://sunrise.example\",\n      \"supportEmail\": \"support@sunrise.example\",\n      \"phoneNumber\": \"+233201234567\"\n    }\n  }\n}"
            },
            "url": "{{baseUrl}}{{graphqlPath}}"
          }
        },
        {
          "name": "Verify Onboarding Email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation VerifyOnboardingEmail($token: String!) { verifyOrganizationOnboardingEmail(token: $token) { nextAction onboarding { administratorStatus onboardingStatus currentStep } } }\",\n  \"variables\": {\n    \"token\": \"{{email_verification_token}}\"\n  }\n}"
            },
            "url": "{{baseUrl}}{{graphqlPath}}"
          }
        },
        {
          "name": "Platform Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const payload = pm.response.json();",
