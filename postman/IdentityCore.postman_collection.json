          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Client-Id", "value": "{{api_client_id}}" },
              { "key": "Authorization", "value": "Bearer {{api_client_secret}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"external_reference\": \"customer_12345\",\n  \"purpose\": \"Customer onboarding verification\",\n  \"verification_subject\": {\n    \"full_name\": \"Akosua Owusu\",\n    \"email\": \"akosua@example.com\",\n    \"phone_number\": \"+233500000000\"\n  },\n  \"metadata\": {\n    \"source\": \"postman\"\n  }\n}"
