                  "const payload = pm.response.json();",
                  "pm.environment.set('verification_id', payload.data.id);",
                  "pm.environment.set('verification_session_id', payload.data.session_id);",
                  "if (payload.data.verification_url) { pm.environment.set('verification_url', payload.data.verification_url); }"
