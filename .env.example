COMPOSE_PROJECT_NAME=identitycore

DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=unsafe-development-secret-key-for-identitycore
JWT_SIGNING_KEY=unsafe-development-jwt-signing-key-for-identitycore-change-me-64
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,django
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DJANGO_TIME_ZONE=UTC

POSTGRES_DB=identitycore
POSTGRES_USER=identitycore
POSTGRES_PASSWORD=identitycore
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

AI_SERVICE_BASE_URL=http://ai-service:8001
AI_SERVICE_SHARED_TOKEN=6cf0f768c9c51700ac7c3fe17648c01fe959542289277b50a19994ed89178631
AI_SERVICE_MODE=real

# AI models are resolved from this single root:
# /opt/identitycore/models
#   ├── insightface/buffalo_l
#   ├── paddleocr/det
#   ├── paddleocr/rec
#   ├── paddleocr/cls
#   ├── mediapipe
#   └── onnx
AI_MODEL_ROOT=/opt/identitycore/models
INSIGHTFACE_MODEL_NAME=buffalo_l
# Set to 1 to let InsightFace download missing model assets automatically.
# Set to 0 when you want to require preloaded local models under AI_MODEL_ROOT.
INSIGHTFACE_ALLOW_DOWNLOAD=0
PADDLE_OCR_LANG=en
PADDLE_OCR_VERSION=PP-OCRv5
# Set to 1 to let PaddleOCR download missing model assets automatically.
# Set to 0 when you want to require preloaded local models under AI_MODEL_ROOT.
PADDLE_OCR_ALLOW_DOWNLOAD=0

UPLOAD_URL_BASE=http://localhost:9000/mock-upload
MEDIA_DOWNLOAD_URL_BASE=http://localhost:9000/mock-download
PUBLIC_ASSET_URL_BASE=https://assets.identitycore.local
ACCOUNT_EMAIL_VERIFICATION_BASE_URL=http://localhost:3000/onboarding/verify-email
APPLICATION_ENCRYPTION_KEYRING=
APPLICATION_ENCRYPTION_ACTIVE_KEY_ID=
OBJECT_STORAGE_PROVIDER=cloudflare_r2

# Bucket routing
# - TEMP: all newly uploaded files land here first via presigned upload URLs
#   prefixes: uploads/documents/, uploads/selfies/, uploads/liveness/
# - MEDIA: consumed verification media is moved here after upload finalization
#   prefixes: uploads/documents/, uploads/selfies/, uploads/liveness/
# - EVIDENCE: reserved for evidence bundles / compliance exports
# - PUBLIC: reserved for non-sensitive public assets
OBJECT_STORAGE_BUCKET=identitycore-media
OBJECT_STORAGE_MEDIA_BUCKET=identitycore-media
OBJECT_STORAGE_TEMP_BUCKET=identitycore-temp
OBJECT_STORAGE_EVIDENCE_BUCKET=identitycore-evidence
OBJECT_STORAGE_PUBLIC_BUCKET=identitycore-public
OBJECT_STORAGE_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
OBJECT_STORAGE_ACCESS_KEY_ID=<your-access-key-id>
OBJECT_STORAGE_SECRET_ACCESS_KEY=<your-secret-access-key>
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_SIGNATURE_VERSION=s3v4
OBJECT_STORAGE_USE_PATH_STYLE=0
OBJECT_STORAGE_ENFORCE_SERVER_SIDE_ENCRYPTION=1
OBJECT_STORAGE_SERVER_SIDE_ENCRYPTION=AES256
OBJECT_STORAGE_KMS_KEY_ID=
APP_MANAGED_MEDIA_ENCRYPTION_ENABLED=1

# Cloudflare R2 aliases; these are supported when OBJECT_STORAGE_* is not set.
R2_ACCESS_KEY_ID=<your-r2-access-key-id>
R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
R2_ACCOUNT_ID=<your-r2-account-id>
R2_ENDPOINT_URL=https://<your-r2-account-id>.r2.cloudflarestorage.com
R2_REGION=auto

# Buckets
R2_MEDIA_BUCKET=identitycore-media
R2_TEMP_BUCKET=identitycore-temp
R2_EVIDENCE_BUCKET=identitycore-evidence
R2_PUBLIC_BUCKET=identitycore-public

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@identitycore.local
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_TIMEOUT=10
NOTIFICATION_EMAIL_PROVIDER=django
NOTIFICATION_EMAIL_PROVIDER_CODE=default-email
NOTIFICATION_SMS_PROVIDER=stub
NOTIFICATION_SMS_PROVIDER_CODE=default-sms
